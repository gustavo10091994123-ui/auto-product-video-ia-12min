# ============================================
# AUTO PRODUCT VIDEO IA - CONFIGURACIÓN
# ============================================

# OpenAI API Configuration
OPENAI_API_KEY="sk-your-api-key-here"
OPENAI_MODEL="gpt-4"
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Runway ML Configuration
RUNWAY_API_KEY="your-runway-api-key"
RUNWAY_MODEL="gen3"
RUNWAY_QUALITY="high"

# ElevenLabs Configuration
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"
ELEVENLABS_VOICE_STABILITY=0.5
ELEVENLABS_VOICE_SIMILARITY=0.75

# Google Translate Configuration
GOOGLE_TRANSLATE_API_KEY="your-google-translate-api-key"
GOOGLE_CLOUD_PROJECT_ID="your-project-id"

# Video Configuration
VIDEO_DURATION=12
VIDEO_QUALITY="1080p"
VIDEO_FORMAT="mp4"
VIDEO_FPS=30
VIDEO_BITRATE="8000k"

# Audio Configuration
AUDIO_SAMPLE_RATE=44100
AUDIO_BITRATE="128k"
AUDIO_LANGUAGE="es"

# Subtitle Configuration
SUBTITLE_FORMAT="srt"
SUBTITLE_LANGUAGES="en,ru,zh"
SUBTITLE_FONT_SIZE=24
SUBTITLE_POSITION="bottom"

# Paths Configuration
PROJECT_DIR="$(pwd)"
DATA_DIR="${PROJECT_DIR}/data"
PRODUCTS_DIR="${DATA_DIR}/products"
OUTPUTS_DIR="${DATA_DIR}/outputs"
VIDEOS_OUTPUT_DIR="${OUTPUTS_DIR}/videos"
SUBTITLES_OUTPUT_DIR="${OUTPUTS_DIR}/subtitles"
SCRIPTS_OUTPUT_DIR="${OUTPUTS_DIR}/scripts"
NARRATION_OUTPUT_DIR="${OUTPUTS_DIR}/narration"
LOGS_DIR="${OUTPUTS_DIR}/logs"
TEMP_DIR="/tmp/product_video_ia_$$"

# General Configuration
DEFAULT_LANGUAGE="es"
LOG_LEVEL="INFO"
VERBOSE=false
DEBUG=false

# Web Scraping Configuration
SCRAPER_TIMEOUT=30
SCRAPER_RETRIES=3
SCRAPER_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

# Processing Configuration
MAX_WORKERS=4
KEEP_TEMP_FILES=false
COMPRESS_VIDEOS=true

# Notification Configuration
ENABLE_NOTIFICATIONS=false
NOTIFICATION_EMAIL=""

# Advanced Configuration
ENABLE_CACHING=true
CACHE_DURATION=604800
ENABLE_RETRY_ON_ERROR=true
MAX_RETRIES=3
RETRY_DELAY=5

# API Endpoints (usually don't need to change)
OPENAI_API_ENDPOINT="https://api.openai.com/v1"
RUNWAY_API_ENDPOINT="https://api.runwayml.com"
ELEVENLABS_API_ENDPOINT="https://api.elevenlabs.io"
GOOGLE_TRANSLATE_ENDPOINT="https://translation.googleapis.com/language/translate/v2"
